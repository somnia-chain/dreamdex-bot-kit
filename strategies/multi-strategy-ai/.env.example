# Copy to .env and fill in. Inherits PRIVATE_KEY / NETWORK from the repo-root .env
# if you run from there; otherwise set them here too.
PRIVATE_KEY=0x...
NETWORK=testnet

# Safe by default: logs intended orders without sending transactions.
# Set DRY_RUN=false to go live.
DRY_RUN=true

SYMBOL=WETH:USDso
MSA_LOOP_MS=60000
MSA_NOTIONAL_USDSO=25
MSA_CROSS_BPS=8
MSA_TAKE_PROFIT_PCT=0.012
MSA_STOP_LOSS_PCT=0.01
MSA_MAX_RISK_PERCENT=0.15
MSA_MAX_LOSS_PERCENT=0.5
MSA_WINDOW_SIZE=40

# Feature flags — enable/disable ensemble modules and the LLM brain.
FEATURES_MOMENTUM=true
FEATURES_MEAN_REVERSION=true
FEATURES_GRID=true
FEATURES_AI=false

# OpenAI-compatible LLM (used only when FEATURES_AI=true).
# Works with OpenAI, or local Ollama via OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=45000
